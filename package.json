{
  "name": "@jrtilak/lazykit",
  "version": "2.0.0",
  "private": true,
  "description": "Copyable TypeScript utilities and React hooks.",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter @lazykit/web dev",
    "build": "bun run --filter @lazykit/web build",
    "check": "bun run check:functions && bun run --filter @lazykit/web check",
    "check:functions": "tsc -p tsconfig.functions.json",
    "preview": "bun run --filter @lazykit/web preview",
    "test": "bun test",
    "test:functions": "bun test registry/functions",
    "test:hooks": "bun test registry/react-hooks",
    "prepare": "husky"
  },
  "keywords": [
    "typescript",
    "utilities",
    "react-hooks"
  ],
  "author": "Tilak Thapa <https://jrtilak.dev>",
  "license": "MIT",
  "repository": "https://github.com/jrTilak/lazykit.git",
  "devDependencies": {
    "@commitlint/cli": "^19.2.0",
    "@commitlint/config-conventional": "^19.1.0",
    "@happy-dom/global-registrator": "^20.11.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.1",
    "typescript": "^6.0.3",
    "husky": "^9.0.11",
    "react": "^18.3.1",
    "@types/bun": "^1.3.14",
    "react-dom": "^18.3.1"
  }
}
