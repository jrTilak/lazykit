{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "ES2022.Intl", "DOM", "DOM.Iterable"],
    "types": ["bun"],
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true
  },
  "include": [
    "registry/functions/*.ts",
    "tests/*.types.ts"
  ],
  "exclude": [
    "registry/functions/*.test.ts"
  ]
}
