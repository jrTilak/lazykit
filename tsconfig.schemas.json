{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["bun"],
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true
  },
  "include": [
    "registry/zod-schemas/*.ts",
    "tests/zod-schemas/*.types.ts"
  ],
  "exclude": [
    "registry/zod-schemas/*.test.ts"
  ]
}
